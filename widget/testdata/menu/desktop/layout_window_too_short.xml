<canvas size="100x50">
	<content>
		<rectangle size="100x50"/>
	</content>
	<overlay>
		<widget size="100x50" type="*widget.OverlayContainer">
			<widget pos="10,10" size="66x40" type="*widget.Menu">
				<rectangle radius="4" shadowBlurRadius="6" shadowColor="shadow" shadowOffset="0,2" size="66x40"/>
				<widget size="66x40" type="*widget.Scroll">
					<widget size="66x162" type="*widget.menuBox">
						<rectangle fillColor="menuBackground" radius="4" size="66x162"/>
						<container size="66x162">
							<widget size="66x35" type="*widget.menuItem">
								<text pos="8,8" size="50x19">A</text>
							</widget>
							<widget pos="0,39" size="66x1" type="*widget.Separator">
								<rectangle fillColor="separator" size="66x1"/>
							</widget>
							<widget pos="0,44" size="66x35" type="*widget.menuItem">
								<text pos="8,8" size="50x19">B (long)</text>
							</widget>
							<widget pos="0,83" size="66x35" type="*widget.menuItem">
								<text pos="8,8" size="30x19">C</text>
								<image pos="46,7" rsc="menuExpandIcon" size="iconInlineSize" themed="foreground"/>
							</widget>
							<widget pos="0,122" size="66x1" type="*widget.Separator">
								<rectangle fillColor="separator" size="66x1"/>
							</widget>
							<widget pos="0,127" size="66x35" type="*widget.menuItem">
								<text pos="8,8" size="30x19">D</text>
								<image pos="46,7" rsc="menuExpandIcon" size="iconInlineSize" themed="foreground"/>
							</widget>
						</container>
					</widget>
					<widget pos="0,40" size="66x0" type="*widget.Shadow">
						<linearGradient endColor="shadow" pos="0,-8" size="66x8"/>
					</widget>
					<widget pos="60,0" size="6x40" type="*widget.scrollBarArea">
						<widget pos="3,0" size="3x16" type="*widget.scrollBar">
							<rectangle fillColor="scrollbar" radius="3" size="3x16"/>
						</widget>
					</widget>
				</widget>
			</widget>
		</widget>
	</overlay>
</canvas>
