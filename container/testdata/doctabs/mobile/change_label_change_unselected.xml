<canvas size="150x150">
	<content>
		<widget size="150x150" type="*container.DocTabs">
			<container size="150x36">
				<widget size="110x36" type="*widget.Scroll">
					<container size="151x36">
						<widget size="73x36" type="*container.tabButton">
							<text bold color="primary" pos="8,8" size="57x20" textSize="11">New 1</text>
							<widget pos="49,8" size="20x20" type="*container.tabCloseButton">
								<image rsc="cancelIcon" size="iconInlineSize" themed="primary"/>
							</widget>
						</widget>
						<widget pos="77,0" size="73x36" type="*container.tabButton">
							<text bold pos="8,8" size="57x20" textSize="11">New 2</text>
							<widget pos="49,8" size="20x20" type="*container.tabCloseButton">
								<image rsc="cancelIcon" size="iconInlineSize" themed="foreground"/>
							</widget>
						</widget>
					</container>
					<widget pos="110,0" size="0x36" type="*widget.Shadow">
						<linearGradient angle="270" endColor="shadow" pos="-8,0" size="8x36"/>
					</widget>
					<widget pos="0,30" size="110x6" type="*widget.scrollBarArea">
						<widget pos="0,3" size="79x3" type="*widget.scrollBar">
							<rectangle fillColor="scrollbar" radius="3" size="79x3"/>
						</widget>
					</widget>
				</widget>
				<container pos="114,0" size="36x36">
					<widget size="36x36" type="*widget.Button">
						<rectangle radius="4" size="36x36"/>
						<rectangle size="36x36"/>
						<image fillMode="contain" pos="8,8" rsc="more-horizontal.svg" size="iconInlineSize" themed="foreground"/>
					</widget>
				</container>
			</container>
			<rectangle fillColor="shadow" pos="0,36" size="150x1"/>
			<rectangle fillColor="primary" pos="0,36" radius="4" size="73x1"/>
			<widget pos="0,40" size="150x110" type="*widget.Label">
				<widget size="150x110" type="*widget.RichText">
					<text pos="8,8" size="34x19">Text1</text>
				</widget>
			</widget>
		</widget>
	</content>
</canvas>
